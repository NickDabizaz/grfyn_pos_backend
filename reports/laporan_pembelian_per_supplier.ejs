<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Laporan Pembelian Per Supplier</title>
  <link rel="stylesheet" href="/reports/laporan_style.css">
  <style>@media print { .no-print { display: none; } }</style>
</head>
<body>
  <div class="no-print" style="text-align:right;margin-bottom:10px;">
    <button onclick="window.print()" style="padding:8px 16px;background:#C4683D;color:#fff;border:none;border-radius:8px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-weight:600;">Cetak</button>
  </div>

  <div class="report-header">
    <% if (logo) { %><img class="logo" src="<%= logo %>" alt="Logo"><% } %>
    <h2><%= namatoko %></h2>
    <p class="subtitle"><%= alamat %> | <%= hp %></p>
    <h3>LAPORAN PEMBELIAN PER SUPPLIER</h3>
  </div>

  <div class="report-meta">
    <span>Periode: <span class="periode"><%= tglwal %> s/d <%= tglakhir %></span></span>
    <span>Tanggal Cetak: <%= tglcetak %></span>
  </div>

  <table>
    <thead>
      <tr>
        <th class="center">No</th>
        <th>Kode Supplier</th>
        <th>Nama Supplier</th>
        <th class="center">Total Transaksi</th>
        <th class="right">Total Pembelian</th>
      </tr>
    </thead>
    <tbody>
      <% data.forEach(function(row, i) { %>
      <tr>
        <td class="center"><%= i + 1 %></td>
        <td><%= row.kodesupplier || '-' %></td>
        <td><%= row.namasupplier || '-' %></td>
        <td class="center"><%= row.total_transaksi || 0 %></td>
        <td class="right">Rp <%= Number(row.total_pembelian || 0).toLocaleString('id-ID') %></td>
      </tr>
      <% }); %>
    </tbody>
    <tfoot>
      <tr>
        <td colspan="4">TOTAL</td>
        <td class="right">Rp <%= Number(grandTotal).toLocaleString('id-ID') %></td>
      </tr>
    </tfoot>
  </table>

  <div class="report-footer">
    <p>&copy; <%= namatoko %> - Generated by Grfyn POS</p>
  </div>
</body>
</html>
