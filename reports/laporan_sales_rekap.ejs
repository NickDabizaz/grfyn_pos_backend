<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Rekap Laporan Penjualan</title>
  <link rel="stylesheet" href="/reports/laporan_style.css">
  <style>@media print { .no-print { display: none; } }</style>
</head>
<body>
  <div class="no-print" style="text-align:right;margin-bottom:10px;">
    <button onclick="window.print()" style="padding:8px 16px;background:#C4683D;color:#fff;border:none;border-radius:8px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-weight:600;">Cetak</button>
  </div>

  <div class="report-header">
    <% if (logo) { %><img class="logo" src="<%= logo %>" alt="Logo"><% } %>
    <h2><%= namatoko %></h2>
    <p class="subtitle"><%= alamat %> | <%= hp %></p>
    <h3>REKAP LAPORAN PENJUALAN</h3>
  </div>

  <div class="report-meta">
    <span>Periode: <span class="periode"><%= tglwal %> s/d <%= tglakhir %></span></span>
    <span>Tanggal Cetak: <%= tglcetak %></span>
  </div>

  <table>
    <thead>
      <tr>
        <th>Keterangan</th>
        <th class="right">Nilai</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Total Transaksi</td>
        <td class="right"><%= data.total_transaksi || 0 %> transaksi</td>
      </tr>
      <tr>
        <td>Total Penjualan</td>
        <td class="right">Rp <%= Number(data.total_penjualan || 0).toLocaleString('id-ID') %></td>
      </tr>
      <tr>
        <td>Total Tunai</td>
        <td class="right">Rp <%= Number(data.total_tunai || 0).toLocaleString('id-ID') %></td>
      </tr>
      <tr>
        <td>Total Non Tunai</td>
        <td class="right">Rp <%= Number(data.total_nontunai || 0).toLocaleString('id-ID') %></td>
      </tr>
      <tr>
        <td>Total Sudah Dibayar</td>
        <td class="right">Rp <%= Number(data.total_sudah_dibayar || 0).toLocaleString('id-ID') %></td>
      </tr>
      <tr>
        <td>Total Piutang</td>
        <td class="right">Rp <%= Number(data.total_piutang || 0).toLocaleString('id-ID') %></td>
      </tr>
    </tbody>
  </table>

  <div class="report-footer">
    <p>&copy; <%= namatoko %> - Generated by Grfyn POS</p>
  </div>
</body>
</html>
