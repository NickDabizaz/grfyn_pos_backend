<% if (locals.success) { %>
  <div class="mb-4 p-3 bg-green-500/10 border border-green-500/30 rounded-lg text-sm text-green-400 flex items-center gap-2">
    <i data-lucide="check-circle" class="w-4 h-4"></i> <%= success %>
  </div>
<% } %>

<% if (locals.error) { %>
  <div class="mb-4 p-3 bg-red-500/10 border border-red-500/30 rounded-lg text-sm text-red-400"><%= error %></div>
<% } %>

<div class="mb-6">
  <h1 class="text-xl font-bold text-white">Maintenance</h1>
  <p class="text-sm text-gray-500 mt-1">System maintenance tools & pool info</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div>
    <h2 class="text-sm font-semibold text-white mb-3">Log Files</h2>
    <div class="bg-gray-900 border border-gray-800 rounded-xl">
      <% if (logFiles.length === 0) { %>
        <div class="p-6 text-center text-gray-500 text-sm">No log files found</div>
      <% } else { %>
        <div class="divide-y divide-gray-800">
          <% logFiles.forEach(f => { %>
          <div class="px-4 py-3 flex items-center justify-between">
            <div><div class="text-sm text-gray-300 font-mono"><%= f.name %></div><div class="text-xs text-gray-500"><%= new Date(f.modified).toLocaleString('id-ID') %></div></div>
            <div class="text-xs text-gray-400"><%= f.size %> KB</div>
          </div>
          <% }); %>
        </div>
      <% } %>
      <div class="px-4 py-3 border-t border-gray-800">
        <form id="form-clear-logs" method="POST" action="/developer/maintenance/clear-logs">
          <button type="button" onclick="openModal('modal-clear-logs')" class="bg-red-600 hover:bg-red-500 text-white px-4 py-2 rounded-lg text-sm transition-colors flex items-center gap-2">
            <i data-lucide="trash-2" class="w-4 h-4"></i> Hapus Semua Log
          </button>
        </form>
      </div>
    </div>
  </div>

  <div>
    <h2 class="text-sm font-semibold text-white mb-3">Connection Pool Info</h2>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 space-y-4">
      <% const items = [
        { label: 'Max Connections', value: poolInfo.maxConnections },
        { label: 'Threads Connected', value: poolInfo.threadsConnected },
        { label: 'Threads Running', value: poolInfo.threadsRunning },
        { label: 'Threads Created', value: poolInfo.threadsCreated },
        { label: 'Total Connections', value: poolInfo.totalConnections }
      ]; %>
      <% items.forEach(item => { %>
        <div class="flex items-center justify-between"><span class="text-sm text-gray-400"><%= item.label %></span><span class="text-sm font-semibold text-white font-mono"><%= item.value %></span></div>
      <% }); %>
    </div>

    <h2 class="text-sm font-semibold text-white mb-3 mt-6">Environment Variables (Safe)</h2>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
      <% const entries = Object.entries(envVars); %>
      <% if (entries.length === 0) { %><p class="text-sm text-gray-500">No variables to display</p><% } else { %>
        <div class="space-y-2"><% entries.forEach(([key, val]) => { %>
          <div class="flex items-center justify-between text-sm"><span class="text-gray-400 font-mono"><%= key %></span><span class="text-white font-mono"><%= val %></span></div>
        <% }); %></div>
      <% } %>
    </div>
  </div>
</div>

<!-- Modal Konfirmasi Hapus Semua Log -->
<div id="modal-clear-logs" class="fixed inset-0 z-50 items-center justify-center p-4" style="display:none">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeModal('modal-clear-logs')"></div>
  <div class="relative bg-gray-900 border border-gray-700 rounded-2xl shadow-2xl w-full max-w-sm p-6">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-full bg-red-500/15 flex items-center justify-center shrink-0">
        <i data-lucide="trash-2" class="w-5 h-5 text-red-400"></i>
      </div>
      <div>
        <h3 class="text-base font-semibold text-white">Hapus Semua Log</h3>
        <p class="text-xs text-gray-400 mt-0.5">Tindakan ini tidak bisa dibatalkan</p>
      </div>
    </div>
    <p class="text-sm text-gray-300 mb-6">Semua file log akan dihapus permanen. Yakin ingin melanjutkan?</p>
    <div class="flex gap-3 justify-end">
      <button type="button" onclick="closeModal('modal-clear-logs')" class="px-4 py-2 bg-gray-800 hover:bg-gray-700 border border-gray-700 text-white text-sm rounded-lg transition-colors">
        Batal
      </button>
      <button type="button" onclick="document.getElementById('form-clear-logs').submit()" class="px-4 py-2 bg-red-600 hover:bg-red-500 text-white text-sm font-medium rounded-lg transition-colors flex items-center gap-2">
        <i data-lucide="trash-2" class="w-4 h-4"></i> Ya, Hapus
      </button>
    </div>
  </div>
</div>

<script>
  function openModal(id) {
    var el = document.getElementById(id);
    if (el) el.style.display = 'flex';
  }
  function closeModal(id) {
    var el = document.getElementById(id);
    if (el) el.style.display = 'none';
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('[id^="modal-"]').forEach(function(m) { m.style.display = 'none'; });
    }
  });
  if (typeof lucide !== 'undefined') lucide.createIcons();
</script>
