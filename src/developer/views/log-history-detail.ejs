<div class="mb-6 flex items-center justify-between gap-3">
  <div>
    <h1 class="text-xl font-bold text-white">Detail Log History</h1>
    <p class="text-sm text-gray-500 mt-1 font-mono"><%= fileName %></p>
  </div>
  <div class="flex items-center gap-2">
    <button
      type="button"
      onclick="copyJson(this)"
      class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700 text-sm text-gray-300 hover:text-white transition-colors"
    >
      <i data-lucide="copy" class="w-4 h-4"></i>
      <span>Copy</span>
    </button>
    <a href="/developer/logs/history" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700 text-sm text-gray-300 hover:text-white transition-colors">
      <i data-lucide="arrow-left" class="w-4 h-4"></i>
      Kembali
    </a>
  </div>
</div>

<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
  <div class="px-4 py-3 border-b border-gray-800 flex items-center justify-between">
    <div class="text-xs text-gray-500">JSON Viewer</div>
    <div class="text-xs text-gray-600">Read only</div>
  </div>
  <pre id="json-viewer" class="p-4 text-xs text-gray-300 overflow-auto whitespace-pre-wrap font-mono leading-relaxed max-h-[72vh]"><%= jsonText %></pre>
</div>

<script>
  function copyJson(button) {
    var el = document.getElementById('json-viewer');
    if (!el) return;
    var text = el.innerText || el.textContent || '';
    var label = button ? button.querySelector('span') : null;
    var old = label ? label.textContent : '';
    function done(ok) {
      if (label) label.textContent = ok ? 'Copied' : 'Failed';
      if (button) {
        button.classList.toggle('text-green-400', ok);
        button.classList.toggle('text-red-400', !ok);
      }
      setTimeout(function() {
        if (label) label.textContent = old || 'Copy';
        if (button) button.classList.remove('text-green-400', 'text-red-400');
      }, 1200);
    }
    if (navigator.clipboard && window.isSecureContext) {
      navigator.clipboard.writeText(text).then(function() { done(true); }).catch(function() { done(false); });
      return;
    }
    var textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.style.position = 'fixed';
    textarea.style.left = '-9999px';
    document.body.appendChild(textarea);
    textarea.focus();
    textarea.select();
    try {
      done(document.execCommand('copy'));
    } catch (_) {
      done(false);
    }
    document.body.removeChild(textarea);
  }
  if (typeof lucide !== 'undefined') lucide.createIcons();
</script>
